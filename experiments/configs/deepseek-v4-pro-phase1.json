{
  "name": "deepseek-v4-pro-phase1",
  "description": "DeepSeek V4 Pro evaluation, Phase 1: scaled-but-architecturally-complete config (all V4 features active at production dims; only num_hidden_layers, n_routed_experts, vocab_size scaled to fit 1x H100). bf16. fp32 matmul precision='high' for TF32. Top-level torch.compile(model, fullgraph=True). Reports gb count, correctness vs eager (max_abs_diff + bitwise), tier-1 perf (speedup + compile_times). See experiments/deepseek_v4_pro_eval_plan.md.",
  "model": {
    "source": "construct",
    "module": "transformers.models.deepseek_v4",
    "config_class": "DeepseekV4Config",
    "model_class": "DeepseekV4ForCausalLM",
    "transformers_branch": "huggingface/transformers@add-deepseek-v4 (PR #45643)",
    "transformers_branch_sha": "a0a8482927a1ef14b1e62cd4d932e9bc29a2cd77",
    "config_kw": {
      "vocab_size": 4096,
      "hidden_size": 7168,
      "num_hidden_layers": 4,
      "num_attention_heads": 128,
      "num_key_value_heads": 1,
      "head_dim": 512,
      "qk_rope_head_dim": 64,
      "q_lora_rank": 1536,
      "o_groups": 16,
      "o_lora_rank": 1024,
      "n_routed_experts": 16,
      "n_shared_experts": 1,
      "num_experts_per_tok": 4,
      "moe_intermediate_size": 3072,
      "max_position_embeddings": 4096,
      "num_hash_layers": 3,
      "compress_ratios": [128, 4, 0, 4],
      "sliding_window": 128,
      "hc_mult": 4,
      "hc_sinkhorn_iters": 20,
      "hc_eps": 1e-06,
      "index_n_heads": 64,
      "index_head_dim": 128,
      "index_topk": 256,
      "num_nextn_predict_layers": 0,
      "scoring_func": "sqrtsoftplus",
      "routed_scaling_factor": 2.5,
      "swiglu_limit": 10.0,
      "rope_theta": 10000.0,
      "compress_rope_theta": 160000.0,
      "rms_norm_eps": 1e-06,
      "attention_bias": false,
      "attention_dropout": 0.0,
      "tie_word_embeddings": false,
      "torch_dtype": "bfloat16"
    }
  },
  "compile": {
    "fullgraph": true,
    "backend": "inductor"
  },
  "settings": {
    "device": "cuda",
    "dtype": "bfloat16",
    "matmul_precision": "high",
    "input_shape": {"batch": 1, "seq_len": 16},
    "perf": {"n_warmup": 10, "n_repeat": 30, "warm_peak_mem": true},
    "tolerance_max_abs_diff": 0.0001,
    "seed": 1337
  },
  "output_dir": "experiments/results/deepseek_v4_pro/phase1-tiny-{date}/"
}
